model UserMonitoringHistory {
  id        BigInt    @id @default(autoincrement())
  userId    String    @db.Uuid @map("user_id")
  ticker    String    @db.VarChar(10)
  action    String    @db.VarChar(20)
  actionAt  DateTime  @default(now()) @db.Timestamptz(6) @map("action_at")
  createdAt DateTime  @default(now()) @db.Timestamptz(6) @map("created_at")

  user  User  @relation(fields: [userId], references: [userId], onDelete: Cascade)
  stock Stock @relation(fields: [ticker], references: [ticker], onDelete: Cascade)

  @@index([userId], name: "idx_user_monitoring_history_user_id")
  @@index([actionAt(sort: Desc)], name: "idx_user_monitoring_history_action_at")
  @@map("user_monitoring_history")
}

// ─────────────────────────────────────────────────────────────────────────────
// ALERTS — per-user (RFC-002 §alerts)
// ─────────────────────────────────────────────────────────────────────────────

model Alert {
  id             BigInt    @id @default(autoincrement())
  userId         String    @db.Uuid @map("user_id")
  ticker         String    @db.VarChar(10)
  alertType      String    @db.VarChar(50) @map("alert_type")
  alertFamily    String    @db.VarChar(20) @map("alert_family")
  priority       String    @db.VarChar(10)
  summaryText    String    @db.Text @map("summary_text")
  detailPayload  Json      @map("detail_payload")
  activeCode     String?   @db.VarChar(5) @map("active_code")
  valuationZone  String?   @db.VarChar(20) @map("valuation_zone")
  currentMultiple Decimal? @db.Decimal(10, 2) @map("current_multiple")
  thresholdSource String?  @db.VarChar(20) @map("threshold_source")
  alertState     String    @default("active") @db.VarChar(20) @map("alert_state")
  triggeredAt    DateTime  @default(now()) @db.Timestamptz(6) @map("triggered_at")
  resolvedAt     DateTime? @db.Timestamptz(6) @map("resolved_at")
  // dedup_key: SHA256(user_id + ticker + alert_type + zone + active_code)
  dedupKey       String    @db.VarChar(100) @map("dedup_key")
  suppressed     Boolean   @default(false)
  createdAt      DateTime  @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt      DateTime  @updatedAt @db.Timestamptz(6) @map("updated_at")

  user         User         @relation(fields: [userId], references: [userId], onDelete: Cascade)
  stock        Stock        @relation(fields: [ticker], references: [ticker], onDelete: Cascade)
  alertHistory AlertHistory[]

  @@index([userId], name: "idx_alerts_user_id")
  @@index([ticker], name: "idx_alerts_ticker")
  @@index([alertState], name: "idx_alerts_alert_state")
  @@index([priority], name: "idx_alerts_priority")
  @@index([alertFamily], name: "idx_alerts_alert_family")
  @@index([triggeredAt(sort: Desc)], name: "idx_alerts_triggered_at")
  @@index([valuationZone], name: "idx_alerts_valuation_zone")
  // Partial unique index for dedup and partial index for active alerts added via raw SQL migration
  @@map("alerts")
}

model AlertHistory {
  id              BigInt    @id @default(autoincrement())
  alertId         BigInt    @map("alert_id")
  userId          String    @db.Uuid @map("user_id")
  ticker          String    @db.VarChar(10)
  oldAlertState   String?   @db.VarChar(20) @map("old_alert_state")
  newAlertState   String?   @db.VarChar(20) @map("new_alert_state")
  transitionReason String?  @db.VarChar(50) @map("transition_reason")
  transitionedAt  DateTime  @default(now()) @db.Timestamptz(6) @map("transitioned_at")
  alertSnapshot   Json      @map("alert_snapshot")
  createdAt       DateTime  @default(now()) @db.Timestamptz(6) @map("created_at")

  alert Alert @relation(fields: [alertId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [userId], onDelete: Cascade)
  stock Stock @relation(fields: [ticker], references: [ticker], onDelete: Cascade)

  @@index([alertId], name: "idx_alert_history_alert_id")
  @@index([ticker], name: "idx_alert_history_ticker")
  @@index([transitionedAt(sort: Desc)], name: "idx_alert_history_transitioned_at")
  @@map("alert_history")
}
