# 3AA Monitoring Product — Environment Variables
# Copy to .env.local for local development
# Production secrets are injected by Cloud Run from Secret Manager — never commit real values

# Database
# Local dev: start Docker test DB with `npm run db:test:up` (port 5433)
# Integration tests: use .env.test (pre-configured for Docker test DB)
# Production: set via Secret Manager (DATABASE_URL secret, version latest)
DATABASE_URL="postgresql://test_user:test_password@localhost:5433/aaa_test"

# Session secret (generate with: openssl rand -base64 32)
SESSION_SECRET="your-session-secret-here"

# Data provider API keys (obtain from provider dashboards)
TIINGO_API_KEY="your-tiingo-api-key"
FMP_API_KEY="your-fmp-api-key"

# Admin API key for user management endpoints (generate with: openssl rand -base64 32)
ADMIN_API_KEY="your-admin-api-key"

# LLM Enrichment (EPIC-003.1 — classification flag and qualitative score enrichment)
ANTHROPIC_API_KEY="sk-ant-..."
LLM_MODEL="claude-sonnet-4-6"
LLM_ENRICHMENT_CONFIDENCE_THRESHOLD="0.60"

# Cloud Scheduler audience (only needed when testing cron endpoints locally)
# In production this is set automatically. For local testing, skip verification
# by keeping NODE_ENV=development (verifySchedulerToken bypasses in non-production).
# SCHEDULER_AUDIENCE="https://aaa-web-717628686883.us-central1.run.app"
