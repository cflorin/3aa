# 3AA Monitoring Product — Environment Variables
# Copy to .env.local for local development

# Database (Cloud SQL via Cloud SQL Auth Proxy or Docker for local dev)
# Production: set via Secret Manager in Cloud Run
# Local dev: use Cloud SQL Auth Proxy on port 5432 or Docker on port 5433
DATABASE_URL="postgresql://aaa_user:YOUR_PASSWORD@127.0.0.1:5432/aaa_production"

# Session secret (generate with: openssl rand -base64 32)
SESSION_SECRET="your-session-secret-here"

# Data provider API keys
TIINGO_API_KEY="your-tiingo-api-key"
FMP_API_KEY="your-fmp-api-key"

# Admin API key (generate with: openssl rand -base64 32)
ADMIN_API_KEY="your-admin-api-key"
